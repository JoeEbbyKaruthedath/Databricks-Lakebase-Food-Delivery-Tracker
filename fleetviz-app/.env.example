DATABRICKS_HOST=https://...
PGDATABASE=your_postgres_databaseName
LAKEBASE_ENDPOINT=your_postgres_endpointPath
PGHOST=your_postgres_host
PGPORT=5432
PGSSLMODE=require
# Required for local seed script (auto-detected from Databricks CLI if omitted)
# PGUSER=your_workspace_email@example.com
DATABRICKS_APP_PORT=8000
DATABRICKS_APP_NAME=fleetviz-app
# Required for npm run grant:delivery-app (same value as databricks bundle postgres_branch)
POSTGRES_BRANCH=projects/your-project/branches/production
FLASK_RUN_HOST=0.0.0.0
